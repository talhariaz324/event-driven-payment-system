# Copy to .env and adjust per service. Each service also has its own .env.example.

NODE_ENV=development

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=event-driven-payments
KAFKA_GROUP_ID_PREFIX=eds

# Postgres (payment-service uses its own DB, ledger uses its own, etc.)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/payments

# Redis
REDIS_URL=redis://redis:6379

# Service ports
API_GATEWAY_PORT=3000
PAYMENT_SERVICE_PORT=3001
WALLET_SERVICE_PORT=3002
LEDGER_SERVICE_PORT=3003
NOTIFICATION_SERVICE_PORT=3004

# Outbox poller
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=100

# Observability
LOG_LEVEL=info
