{
  "name": "event-driven-payment-system",
  "version": "0.1.0",
  "private": true,
  "description": "Production-grade event driven payment system using NestJS, Kafka, Redis, PostgreSQL, Outbox Pattern",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint \"{services,packages}/**/src/**/*.ts\"",
    "format": "prettier --write \"{services,packages}/**/src/**/*.ts\"",
    "test": "npm run test --workspaces --if-present",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  }
}
