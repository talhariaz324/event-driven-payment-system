generator client {
  // Each service gets its own generated client so the two schemas
  // (payment-service and wallet-service) don't trample one another in the
  // shared workspace node_modules.
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @db.Uuid
  amount         Decimal       @db.Decimal(18, 4)
  currency       String        @db.VarChar(3)
  status         PaymentStatus @default(INITIATED)
  idempotencyKey String        @unique @map("idempotency_key")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@map("payments")
}

enum PaymentStatus {
  INITIATED
  AUTHORIZED
  SETTLED
  FAILED

  @@map("payment_status")
}

model OutboxEvent {
  id            String      @id @default(uuid()) @db.Uuid
  aggregateType String      @map("aggregate_type")
  aggregateId   String      @map("aggregate_id")
  eventType     String      @map("event_type")
  topic         String
  payload       Json
  status        OutboxStatus @default(PENDING)
  attempts      Int         @default(0)
  createdAt     DateTime    @default(now()) @map("created_at")
  publishedAt   DateTime?   @map("published_at")
  lastError     String?     @map("last_error")

  @@index([status, createdAt])
  @@map("outbox_events")
}

enum OutboxStatus {
  PENDING
  PUBLISHED
  FAILED

  @@map("outbox_status")
}

// Composite primary key on (event_id, consumer): the same event flows to
// multiple consumer groups (wallet, ledger, notification) and each one
// independently marks the event as processed for its own group. A single-
// column PK would make the second consumer's INSERT collide with the first.
model ProcessedEvent {
  eventId     String   @map("event_id")
  consumer    String
  processedAt DateTime @default(now()) @map("processed_at")

  @@id([eventId, consumer])
  @@map("processed_events")
}
