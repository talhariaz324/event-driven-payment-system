{
  "name": "@eds/wallet-service",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "prebuild": "prisma generate --schema=prisma/schema.prisma",
    "build": "nest build",
    "pretest": "prisma generate --schema=prisma/schema.prisma",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "test": "jest"
  },
  "dependencies": {
    "@eds/kafka-core": "*",
    "@eds/shared-types": "*",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/terminus": "^10.2.0",
    "@prisma/client": "^5.10.0",
    "joi": "^17.12.1",
    "kafkajs": "^2.2.4",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "jest": "^30.4.2",
    "prisma": "^5.10.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": ["src/**/*.ts", "!src/generated/**"],
    "coverageDirectory": "./coverage",
    "testPathIgnorePatterns": ["/node_modules/", "/dist/", "/generated/"],
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@eds/(.*)$": "<rootDir>/../../packages/$1/src"
    }
  }
}
