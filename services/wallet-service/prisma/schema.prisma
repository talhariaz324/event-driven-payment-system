generator client {
  // Each service gets its own generated client so the two schemas
  // (payment-service and wallet-service) don't trample one another in the
  // shared workspace node_modules.
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// One wallet per (userId, currency). Real systems would split this further
// (e.g. per ledger account); kept simple here so the consumer flow is
// readable. The `version` column drives optimistic locking — the consumer
// reads it, computes the new balance, and updates only if the version is
// still the one it read. A concurrent debit increments the version and the
// loser retries.
model Wallet {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  currency  String   @db.VarChar(3)
  balance   Decimal  @default(0) @db.Decimal(18, 4)
  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transactions WalletTransaction[]

  @@unique([userId, currency])
  @@map("wallets")
}

// Append-only history. The wallet balance is a materialized derived value
// from these rows; if the balance ever disagrees with the sum of
// transactions we know something has gone wrong and can rebuild.
model WalletTransaction {
  id          String                  @id @default(uuid()) @db.Uuid
  walletId    String                  @map("wallet_id") @db.Uuid
  paymentId   String                  @map("payment_id") @db.Uuid
  amount      Decimal                 @db.Decimal(18, 4)
  type        WalletTransactionType
  reason      String?
  createdAt   DateTime                @default(now()) @map("created_at")

  wallet      Wallet                  @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
  @@index([paymentId])
  @@map("wallet_transactions")
}

enum WalletTransactionType {
  DEBIT
  CREDIT

  @@map("wallet_transaction_type")
}

// Composite primary key on (event_id, consumer) for the same reason as in
// payment-service: the same event flows to multiple consumer groups
// independently. The `consumer` column lets us run multiple consumer groups
// out of one wallet-service deployment in the future without changing the
// schema.
model ProcessedEvent {
  eventId     String   @map("event_id")
  consumer    String
  processedAt DateTime @default(now()) @map("processed_at")

  @@id([eventId, consumer])
  @@map("processed_events")
}
